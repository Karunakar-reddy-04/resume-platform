# ─────────────────────────────────────────────────────────────
# ResumeMatch — Environment Variables
# Copy this file to .env.local for local dev
# Set these as Environment Variables in Vercel dashboard for production
# ─────────────────────────────────────────────────────────────

# DATABASE — Railway PostgreSQL
# Get this from Railway dashboard → your PostgreSQL service → Connect tab
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway"

# NEXTAUTH — Authentication
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate
# NEXTAUTH_URL: your Vercel deployment URL (or http://localhost:3000 for local)
NEXTAUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-app.vercel.app"
